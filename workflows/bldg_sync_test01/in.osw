{
  "seed_file": "seed_empty.osm",
  "file_paths": [
    "../../seeds",
    "../../weather"
  ],
  "measure_paths": [
    "../../../openstudio-common-measures-gem/lib/measures",
    "../../../openstudio-model-articulation-gem/lib/measures"
  ],
  "steps": [
    {
      "measure_dir_name": "set_run_period",
      "arguments": {
        "__SKIP__": false,
        "timesteps_per_hour": "1",
        "begin_date": "2019-01-01",
        "end_date": "2019-12-31"
      }
    },
    {
      "arguments": {
        "weather_file_name": "USA_CO_Golden-NREL.724666_TMY3.epw",
        "climate_zone": "Lookup From Stat File"

      },
      "measure_dir_name": "ChangeBuildingLocation"
    },
    {
      "arguments": {
        "__SKIP__": false,
        "bldg_type_a": "PrimarySchool",
        "total_bldg_floor_area": 73960.0,
        "floor_height": 0,
        "num_stories_above_grade": 1,
        "num_stories_below_grade": 0,
        "building_rotation": 0.0,
        "template": "90.1-2013",
        "ns_to_ew_ratio": 2.8,
        "wwr": 0.35,
        "party_wall_fraction": 0.0,
        "bar_division_method": "Multiple Space Types - Individual Stories Sliced"
      },
      "measure_dir_name": "create_bar_from_building_type_ratios"
    },
    {
      "measure_dir_name": "create_typical_building_from_model",
      "arguments": {
        "__SKIP__": false,
        "template": "90.1-2013",
        "system_type": "PVAV with gas boiler reheat"
      }
    },
    {
      "arguments": {
        "__SKIP__": false
      },
      "measure_dir_name": "view_model"
    },    {
      "measure_dir_name": "SetLightingLoadsByLPD",
      "arguments": {
        "__SKIP__": true
      }
    },
    {
      "measure_dir_name": "set_electric_equipment_loads_by_epd",
      "arguments": {
        "__SKIP__": false,
        "epd": 0.0241425
      }
    },
    {
      "arguments": {
        "zone_condition_section": false
      },
      "measure_dir_name": "openstudio_results"
    }
  ]
}